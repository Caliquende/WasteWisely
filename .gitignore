# Ignore EVERYTHING
*

# Allow the specific folders and files
!src/
!src/**
!frontend/
!frontend/**
!tests/
!tests/**
!installer.py
!build.py

# Allow essential project metadata (not in user list but required for GitHub/pip)
!README.md
!README_TR.md
!requirements.txt
!pyproject.toml
!.gitignore
!HOW_TO_USE.md

# Re-ignore Python junk inside unignored folders
**/__pycache__/
**/*.py[cod]
**/*.log
build/
dist/
*.spec

.agent
.pytest_cache
