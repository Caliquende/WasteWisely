# Ignore EVERYTHING
*

# Allow the specific folders and files
!src/
!src/**
!frontend/
!frontend/**
!public/
!public/**
!server/
!server/**
!tests/
!tests/**
!installer.py
!build.py
!assets/
!assets/**
!index.html
!package.json
!package-lock.json
!vite.config.ts
!tsconfig.json
!tsconfig.app.json
!tsconfig.node.json
!eslint.config.js
!.env.example

# Allow essential project metadata (not in user list but required for GitHub/pip)
!README.md
!README_TR.md
!requirements.txt
!pyproject.toml
!.gitignore
!HOW_TO_USE.md
!.github/
!.github/**
!SECURITY.md
!.pre-commit-config.yaml


# Re-ignore Python junk inside unignored folders
**/__pycache__/
**/*.py[cod]
**/*.log
node_modules/
build/
dist/
dist-ssr/
*.spec
.env
.env.*
!.env.example
*.local
.vscode/*
